# SHIELD-IoT Environment Configuration
# Copy this file to .env and fill in your values

# Anthropic Claude API Key (required for agentic reasoning)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Router API credentials (for automated response executor)
# Leave blank to use simulation mode
ROUTER_IP=192.168.1.1
ROUTER_USERNAME=admin
ROUTER_PASSWORD=

# Server configuration
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Simulation mode (set to true to use simulated network data)
SIMULATION_MODE=true

# Threat intelligence feeds (optional - uses built-in list if not set)
ABUSE_IPDB_API_KEY=

# Log level
LOG_LEVEL=INFO
